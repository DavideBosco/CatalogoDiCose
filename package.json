{
  "name": "catalogo-di-cose",
  "version": "1.0.0",
  "description": "A catalogue of items extrapolated from a JSON file",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "sass-dev": "sass --watch --update --style=expanded src/scss:dist/css",
    "sass-prod": "sass --no-source-map --style=compressed src/scss:dist/css",
    "serve": "browser-sync start --server \"dist\" --files \"dist\" --watch \"dist\"",
    "start": "concurrently \"npm run prepare\" \"npm run serve\" \"npm run sass-dev\" \"npm run watch-images\" \"npm run watch-js\" \"npm run watch-html\"",
    "prepare": "concurrently \"npm run sass-prod\" \"node tools/compress-all-images.js\" \"npx webpack --config webpack.prod.mjs\" \"npm run html-build\"",
    "watch-images": "onchange \"src/img\" -- node tools/image-compress.js {{file}} {{event}}",
    "watch-js": "onchange \"src/js\" -- npx webpack --config webpack.dev.mjs",
    "html-build": "posthtml -c posthtml.json",
    "watch-html": "onchange \"src/views\" \"src/fragments\" -- npm run html-build"
  },
  "author": "Davide Bosco",
  "license": "ISC",
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "htmlnano": "^3.2.0",
    "onchange": "^7.1.0",
    "posthtml": "^0.16.7",
    "posthtml-cli": "^0.10.0",
    "posthtml-modules": "^0.9.1",
    "sass": "^1.97.3",
    "sharp": "^0.34.5",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1"
  }
}
